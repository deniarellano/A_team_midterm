import os
import pandas as pd
import numpy as np
import geopandas as gpd
import matplotlib.pyplot as plt
import seaborn as sns
from shapely.geometry import Point

#Load and Inspect Data
file_path = 'https://raw.githubusercontent.com/deniarellano/A_team_midterm/refs/heads/main/data/raw/zoning_counties.zip'
parcel_df = pd.read_csv(file_path)
parcel_df.head()
parcel_df.tail()
print(parcel_df.columns,'\n')
print(f"Dataset loaded with {parcel_df.shape[0]} rows and {parcel_df.shape[1]} columns.")

parcel_df.info()

"""**Inspect Column Names (.columns)**

* Check for unwanted characters such as #, %, @, etc.
* Identify and remove whitespaces for easier column access
* Standardize case formatting (lowercase is generally easier to handle).
* If necessary, rename columns systematically.

**Data Cleaning**

**Step 1: Standardize Column Names & Drop non-essential columns**
"""

#Remove whitespaces & lower case formatting
cleaned_parcel_df = parcel_df.copy()
cleaned_parcel_df.columns = cleaned_parcel_df.columns.str.replace(' ', '_').str.lower()

cleaned_parcel_df.head()
cleaned_parcel_df.info()

#Drop columns that are not essential
parcel_df_renamed = cleaned_parcel_df.drop(columns=['zn_recid','last_edited','editor_id','zn_code_basis_url','edit_version'])
parcel_df_renamed.head(10)

"""**Data Cleaning**

**Step 2: SB79 Applicable Bay Area Counties**
"""

parcel_df_renamed['zn_county'].value_counts() #Already filtered on ArcGIS before downloading

"""**Data Cleaning**

**Step 3: Check Missing Data Values**
"""

print(parcel_df_renamed.isna().sum())
missing_counties = parcel_df_renamed[parcel_df_renamed['zn_county'].isna()]

print(missing_counties['jurisdiction_id'].value_counts())
#Most missing values are for unicorporated areas

# Missing Land Area
missing_parcels_land_area = missing_counties['shape__area'].sum()
total_parcels_land_area = parcel_df_renamed['shape__area'].sum()
percent_missing = (missing_parcels_land_area / total_parcels_land_area) * 100

print(f"Total Area Missing: {missing_parcels_land_area}")
print(f"Grand Total Area: {total_parcels_land_area}")
print(f"Percentage Missing: {percent_missing:.2f}%")
# 1.26% is not that bad - we can drop the data with missing 'zn_county' values

parcel_df_renamed = parcel_df_renamed.dropna(subset=['zn_county'])
print(parcel_df_renamed.isna().sum())

#drop more columns that are not currently relavant to analysis
parcel_df_renamed = cleaned_parcel_df.drop(columns=['allows_comm_office','zn_min_far','zn_max_far'])

"""**Creating a Geodataframe**"""

parcel_df_geom = gpd.points_from_xy(
    x=parcel_df_renamed['shape__area'],
    y=parcel_df_renamed['shape__length']
)

parcel_df_geom

zoning_parcels_gdf= gpd.GeoDataFrame(
    parcel_df_renamed,
    geometry=parcel_df_geom,
    crs=4326
)

# Display the first few rows
zoning_parcels_gdf.head()

# Calculating percentage of land area per zone for each county
#  = Sum of zoned area type in county / total area of county *100

#Group zn_code by zn_county, and sum the area
zoning_mix = zoning_parcels_gdf.groupby(['zn_county', 'zn_regional_description'])['shape__area'].sum()

#divide by total area of each county
zoning_mix_pct = (zoning_mix / zoning_mix.groupby('zn_county').transform('sum')) * 100

#zoning_mix_pct
#created two long series, so use unstack()
zoning_table = zoning_mix_pct.unstack().fillna(0)

zoning_table

fig, axes = plt.subplots(nrows=2, ncols=2, figsize=(14, 10), sharey=True)
axes_flat = axes.flatten()
#Group Unclassified, Transportation and Mixed-Use Commercial into Other

#Create a mask to group columns not relavant to analysis
mask = zoning_table[['Mixed Use Commercial','Transportation','Unclassified']]

# creating and 'Other' column
zoning_table['Other'] = zoning_table.loc[:, mask.columns].sum(axis=1)
#droping the columns included in 'other'
zoning_table_cleaned = zoning_table.drop(columns=mask.columns)


#Consistent colors for zones - MTC color palette
zoning_colors =  {'Agriculture':'#62902c',
           'Commercial':'#d65850',
           'Conservation and Ecology Areas' : '#aec350',
           'Industrial': '#944fcd',
            'Mixed-Use Residential': '#d7a34c',
            'Multi-Family Residential':'#dd9a37',
           'Parks and Open Space': '#acd278',
           'Public and Institutional':'#5a8cd3',
           'Single Family Residential':'#f1d874',
           'Specific or Special Plan Areas':'#db8582'}

for i, (zn_county, zn_regional_description) in enumerate(zoning_table_cleaned.iterrows()):
     ax = axes_flat[i]

     sorted_zones = zn_regional_description.sort_index(ascending=False)

     bar_colors = [zoning_colors.get(color,'#aaaaaa') for color in sorted_zones.index] #all other category colors are grey

     #zn_regional_description.sort_values().plot(kind='barh', ax=ax, color=colors) - MISTAKE! using sort_values() messed up the chart because it basically colored the graphy by highest values and not by zone
     sorted_zones.plot(kind='barh', ax=ax, color=bar_colors)
     ax.set_xlim(0, 65) #Maximum value is 65

     ax.set_title(f"Zoning: {zn_county} County", fontsize=11, fontweight='light')
     ax.tick_params(axis='y', which='both', left=False)
     ax.spines[['top', 'right']].set_visible(False)
     ax.set_ylabel("")
     if i >= 2:
        ax.set_xlabel('Percentage of Total Land Area (%)')

fig.suptitle('Zoning across SB79 counties in the Bay Area, 2023',fontsize=13, fontweight='bold', y=0.988 )
plt.tight_layout()
plt.show()

